generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PERSONAL
  STUDENT
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  OVERDUE
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum PlanType {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PERSONAL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student      Student?
  workoutPlans WorkoutPlan[]
}

model Student {
  id        String        @id @default(uuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id])
  phone     String?
  birthDate DateTime?
  goal      String?
  plan      PlanType      @default(MONTHLY)
  status    StudentStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  payments     Payment[]
  bodyRecords  BodyRecord[]
  workoutPlans WorkoutPlan[]
}

model Payment {
  id        String        @id @default(uuid())
  studentId String
  student   Student       @relation(fields: [studentId], references: [id])
  amount    Decimal       @db.Decimal(10, 2)
  dueDate   DateTime
  paidAt    DateTime?
  status    PaymentStatus @default(PENDING)
  note      String?
  createdAt DateTime      @default(now())
}

model WorkoutPlan {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  days WorkoutDay[]
}

// Cada dia de treino dentro de uma ficha (Treino A, B, C...)
model WorkoutDay {
  id            String      @id @default(uuid())
  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  label         String      // "Treino A", "Treino B", etc.
  order         Int         @default(0)

  exercises WorkoutExercise[]
}

model Exercise {
  id          String   @id @default(uuid())
  name        String
  muscleGroup String
  description String?
  gifUrl      String?
  createdAt   DateTime @default(now())

  workoutItems WorkoutExercise[]
}

model WorkoutExercise {
  id           String     @id @default(uuid())
  workoutDayId String
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])
  sets         Int
  reps         String
  load         String?
  rest         String?
  order        Int
}

model BodyRecord {
  id         String   @id @default(uuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  weight     Decimal? @db.Decimal(5, 2)
  height     Decimal? @db.Decimal(4, 2)
  bodyFat    Decimal? @db.Decimal(4, 2)
  notes      String?
  recordedAt DateTime @default(now())
}
